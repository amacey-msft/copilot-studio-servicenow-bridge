# --- Azure Bot (NEW resource, separate from the legacy teams_bot) ---
AZURE_BOT_APP_ID=
AZURE_BOT_APP_PASSWORD=
AZURE_BOT_APP_TYPE=SingleTenant
AZURE_BOT_TENANT_ID=
AZURE_BOT_OAUTH_CONNECTION_NAME=mcs

# --- OBO app reg (delegated CopilotStudio.Copilots.Invoke) ---
# Currently UNUSED in Direct-Line parity mode (the bridge holds the DL
# secret). Kept for forward compatibility when CS S2S lands.
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
OBO_TENANT_ID=

# --- Copilot Studio target ---
COPILOTSTUDIO_ENVIRONMENT_ID=
COPILOTSTUDIO_SCHEMA_NAME=
# Optional: only fires if you've added a CS Event node for full Genesys parity.
COPILOTSTUDIO_HANDOFF_EVENT_NAME=ServiceNowHandoff

# --- Bridge (existing Flask app) ---
# When the agent runs in Docker on the same host as the bridge:
#   BRIDGE_INTERNAL_URL=http://host.docker.internal:5001
# When co-located in docker-compose:
#   BRIDGE_INTERNAL_URL=http://bridge:5000
BRIDGE_INTERNAL_URL=http://host.docker.internal:5001
PUSH_SHARED_SECRET=replace-with-shared-secret

# --- Direct Line proxy timing knobs ---
# Max wall-clock to wait for CS bot reply before giving up on a turn
DIRECTLINE_TURN_TIMEOUT_S=12
# How long after the last bot activity before we declare the turn done
DIRECTLINE_QUIET_PERIOD_S=1.5
# Poll interval against DL /activities
DIRECTLINE_POLL_INTERVAL_S=0.5

# --- Hosting ---
PORT=3978
LOG_LEVEL=INFO
