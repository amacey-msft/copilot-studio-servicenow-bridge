# --- Azure Bot (NEW resource, separate from the legacy teams_bot) ---
AZURE_BOT_APP_ID=
AZURE_BOT_APP_PASSWORD=
AZURE_BOT_APP_TYPE=SingleTenant
AZURE_BOT_TENANT_ID=
AZURE_BOT_OAUTH_CONNECTION_NAME=mcs

# --- OBO app reg (delegated CopilotStudio.Copilots.Invoke) ---
OBO_CLIENT_ID=
OBO_CLIENT_SECRET=
OBO_TENANT_ID=

# --- Copilot Studio target ---
COPILOTSTUDIO_ENVIRONMENT_ID=
COPILOTSTUDIO_SCHEMA_NAME=
# Optional: only fires if you've added a CS Event node for full Genesys parity.
COPILOTSTUDIO_HANDOFF_EVENT_NAME=ServiceNowHandoff

# --- Bridge (existing Flask app) ---
BRIDGE_INTERNAL_URL=http://bridge:5000
PUSH_SHARED_SECRET=replace-with-shared-secret

# --- Hosting ---
PORT=3978
LOG_LEVEL=INFO
