# Bridge runtime configuration. Copy to .env and fill in.

# --- Public URL the bridge is reachable on ---
# This is the URL Copilot Studio HTTP tools call AND the URL ServiceNow
# Business Rules POST webhooks to. Set this once and run
# `scripts/sync-bridge-url.ps1` to push it to both platforms in one shot
# instead of clicking through each UI.
#
# When developing locally with `scripts/devtunnel-create.ps1` +
# `scripts/devtunnel-host.ps1`, this is your tunnel URL, e.g.
# https://abc12345-5001.use.devtunnels.ms
BRIDGE_PUBLIC_URL=https://<your-tunnel-or-app-host>

# --- ServiceNow connection ---
# Your instance, e.g. https://dev123456.service-now.com
SN_INSTANCE=https://<your-instance>.service-now.com
# Service account that holds x_intranet_bridge_caller (and the AWA roles, see docs/02-servicenow-setup.md)
SN_USER=intranet.bridge
SN_PASSWORD=replace-me

# Admin credentials used ONLY by scripts/sync-bridge-url.ps1 to PATCH the
# `intranet_bridge.outbound_webhook_url` sys_property. The runtime bridge
# does NOT use these. Leave blank if you will update the sys_property by hand.
SN_ADMIN_USER=
SN_ADMIN_PASSWORD=

# Scripted REST namespace. Default matches the API id assigned by SOW
# when you create the API. Override only if you used a different API id
# (visible in the URL of the Scripted REST API record).
SN_BRIDGE_API_BASE=/api/<api-id>/intranet_bridge

# Default mapping for browser users (used until you wire up real SSO).
# Look these up in SOW and paste the sys_ids here.
SN_DEFAULT_USER_SYS_ID=<sys_user.sys_id of your test consumer>
SN_DEFAULT_QUEUE_SYS_ID=<awa_queue.sys_id of the chat queue agents are members of>
SN_DEFAULT_CHANNEL_SYS_ID=<sys_cs_channel.sys_id for the Chat channel>

# --- Inbound webhook (Business Rule -> bridge) ---
# Long random string. Must match intranet_bridge.outbound_webhook_secret sys_property.
SN_WEBHOOK_SECRET=replace-with-long-random-string

# --- Copilot Studio agent endpoints ---
# Long random string. Sent as X-Agent-Secret header by Copilot Studio HTTP actions.
AGENT_API_SECRET=replace-with-different-long-random-string

# Copilot Studio Direct Line token endpoint for the embedded webchat on the
# reference intranet page. Find it in Copilot Studio under
# Channels -> Custom website -> "Token Endpoint". Format:
#   https://<env-host>.environment.api.powerplatform.com/powervirtualagents/botsbyschema/<schema>/directline/token?api-version=2022-03-01-preview
DIRECTLINE_TOKEN_ENDPOINT=

# Fallback: Direct Line channel secret from your Azure Bot resource.
# Used if DIRECTLINE_TOKEN_ENDPOINT is unset or returns 4xx (e.g. the
# Power Platform "Custom website" channel isn't enabled). The bridge
# never returns this secret to the browser; it's exchanged server-side
# for a short-lived Direct Line token.
DIRECTLINE_SECRET=

# --- Copilot Studio (Dataverse) targets for sync-bridge-url.ps1 ---
# Org URL of the Dataverse environment that hosts your agent
# (e.g. https://orgXXXXXXXX.crm.dynamics.com)
POWERPLATFORM_ORG_URL=
# Dataverse GUID of the bot row (bot.botid). Find with scripts/cps/list-bots.ps1
# or in the Copilot Studio URL: /bots/<this-guid>/overview
POWERPLATFORM_BOT_ID=
# Schema-name prefix used when the agent's HTTP-action botcomponents were created
# (e.g. `awm_contosoithelp`). The script looks for botcomponents named
# `<prefix>.action.CreateServiceNowIncident` and `<prefix>.action.EscalateToLiveITAgent`.
POWERPLATFORM_BOT_SCHEMA=

# --- Optional ---
SN_REQUEST_TIMEOUT=15
PORT=5000

# --- Teams relay bot (optional; teams_bot/) ---
# Leave MS_APP_ID blank to disable the /api/messages endpoint entirely.
# When set, the bridge ALSO acts as the Bot Framework messaging endpoint for
# the Teams app. See docs/11-teams-bot-setup.md (added by feat/teams-channel).
MS_APP_ID=
MS_APP_PASSWORD=
# "MultiTenant" (default), "SingleTenant", or "UserAssignedMSI".
MS_APP_TYPE=MultiTenant
# Required when MS_APP_TYPE=SingleTenant or UserAssignedMSI.
MS_APP_TENANT_ID=

# Internal URL the relay bot uses to reach the bridge's own routes
# (init-session, escalate, user-message, directline/token). Default works
# for the single-container deployment.
BRIDGE_INTERNAL_URL=http://127.0.0.1:5000

# Direct Line proxy tunables (per Teams turn).
DIRECTLINE_TURN_TIMEOUT_S=12
DIRECTLINE_QUIET_PERIOD_S=1.5
DIRECTLINE_POLL_INTERVAL_S=0.5

# --- Teams push target (cutover knob; teams_agent/) ---
# Which downstream sender receives outbound pushes for Teams sessions:
#   legacy  -> in-process teams_bot.push (Bot Framework SDK; default)
#   agent   -> HTTP POST to TEAMS_AGENT_PUSH_URL (M365 Agents SDK port)
#   both    -> fan out to both (use during parity test)
TEAMS_PUSH_TARGET=legacy
# Required if TEAMS_PUSH_TARGET in (agent, both). Base URL of the
# teams_agent/ service (no trailing slash). It exposes /api/teams/push.
TEAMS_AGENT_PUSH_URL=
# Shared secret; must match PUSH_SHARED_SECRET in teams_agent/.env.
TEAMS_AGENT_PUSH_SECRET=
TEAMS_AGENT_PUSH_TIMEOUT_S=10
